#!/bin/bash

source "$CONFIG_DIR/colors.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

# ── Bar ──────────────────────────────────────────────────────
# Style "floating pill" inspiré de la waybar Hyprland
sketchybar --bar height=38 \
  blur_radius=30 \
  position=top \
  sticky=off \
  padding_left=10 \
  padding_right=10 \
  margin=8 \
  y_offset=4 \
  corner_radius=12 \
  border_width=1 \
  border_color=$BAR_BORDER_COLOR \
  color=$BAR_COLOR

# ── Defaults ─────────────────────────────────────────────────
sketchybar --default icon.font="SF Pro:Semibold:14.0" \
  icon.color=$ICON_COLOR \
  label.font="SF Pro:Semibold:13.0" \
  label.color=$LABEL_COLOR \
  background.color=$ITEM_BG_COLOR \
  background.corner_radius=8 \
  background.height=26 \
  background.border_color=$BAR_BORDER_COLOR \
  background.border_width=0 \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=6 \
  label.padding_right=8 \
  icon.padding_left=8 \
  icon.padding_right=4

# ── Left: Workspaces ────────────────────────────────────────
source $ITEM_DIR/spaces.sh
source $ITEM_DIR/space_apps.sh

# ── Center-left (q): Clock ───────────────────────────────────
source $ITEM_DIR/clock.sh

# ── Center-right (e): Front App ──────────────────────────────
source $ITEM_DIR/front_app.sh

# ── Right: Modules ───────────────────────────────────────────
# Ordre d'ajout = droite vers gauche
# Résultat visuel : mullvad | network | volume | battery
source $ITEM_DIR/battery.sh
source $ITEM_DIR/volume.sh
source $ITEM_DIR/network.sh
source $ITEM_DIR/mullvad.sh

# ── Finalize ─────────────────────────────────────────────────
sketchybar --update
